# ── Frontend (Vite-exposed) ──────────────────────────────────────────────
# Get these from Supabase Studio → Project Settings → API.
VITE_SUPABASE_PROJECT_ID=
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# ── Migration runner only — never exposed to the browser ────────────────
# Supabase Studio → Project Settings → Database → Connection string → URI
# Use the pooled "Transaction" connection (port 6543). Looks like:
#   postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
SUPABASE_DB_URL=
