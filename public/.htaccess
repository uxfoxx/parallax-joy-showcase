# Apache / LiteSpeed SPA fallback.
#
# React Router uses client-side paths (/about, /products/:slug, /contact, etc.).
# On a hard-reload or deep-link of any such path, the server would otherwise
# return 404 because there is no matching file on disk. This rewrite sends
# every non-file, non-directory request back to /index.html so the React
# router can resolve the path in the browser.
#
# This file is copied into dist/ at build time by Vite (public/ → dist/),
# and applies on Apache- or LiteSpeed-based hosts such as Namecheap Stellar
# Plus. On Netlify, the existing public/_redirects file handles the same job
# and this rule is ignored.

# Options +FollowSymLinks is required by some cPanel hosts (including
# Namecheap shared plans) before the rewrite engine activates. Without it
# RewriteEngine silently no-ops and deep-links fall through to a 404.
Options +FollowSymLinks -MultiViews

# ── Compression ────────────────────────────────────────────────────────────
# Brotli first (LiteSpeed / newer Apache), gzip fallback. Shrinks the JS/CSS
# bundle ~70% over the wire — the single biggest transfer win.
<IfModule mod_brotli.c>
  AddOutputFilterByType BROTLI_COMPRESS text/html text/plain text/css \
    text/javascript application/javascript application/json application/xml \
    image/svg+xml application/manifest+json
</IfModule>
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css \
    text/javascript application/javascript application/json application/xml \
    image/svg+xml application/manifest+json application/x-font-ttf font/otf
</IfModule>

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # 1. Force HTTPS. Catches both direct http:// requests and any reverse-proxy
  #    chain that arrives over plain HTTP. AutoSSL needs to be live in cPanel
  #    for this to land cleanly; until then the redirect is a soft no-op
  #    because https:// won't respond.
  RewriteCond %{HTTPS} !=on [OR]
  RewriteCond %{HTTP:X-Forwarded-Proto} !https
  RewriteRule ^ https://www.olivefoods.lk%{REQUEST_URI} [L,R=301]

  # 2. Force www. — olivefoods.lk → www.olivefoods.lk so we ship a single
  #    canonical host (matches index.html's <link rel="canonical">).
  RewriteCond %{HTTP_HOST} ^olivefoods\.lk$ [NC]
  RewriteRule ^ https://www.olivefoods.lk%{REQUEST_URI} [L,R=301]

  # 3. SPA fallback — allow the real index.html through, then any real file
  #    or directory, then route everything else back to /index.html so
  #    React Router can resolve client-side deep-links.
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>

# Explicit 404 fallback in case mod_rewrite is unavailable on this host.
ErrorDocument 404 /index.html

# ── Cache-Control ──────────────────────────────────────────────────────────
<IfModule mod_headers.c>
  # Content-hashed Vite build assets never change for a given URL → cache a
  # year, immutable.
  <FilesMatch "\.(js|mjs|css|woff2?|ttf|otf|eot)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  # Static images/media aren't content-hashed → long but revalidatable, so a
  # swapped asset can still refresh (not pinned for a year).
  <FilesMatch "\.(png|jpe?g|gif|webp|avif|svg|ico|mp4|webmanifest)$">
    Header set Cache-Control "public, max-age=2592000"
  </FilesMatch>
  # HTML must always revalidate so a new deploy is picked up immediately.
  <FilesMatch "\.html$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
</IfModule>

# Fallback TTLs for hosts with mod_expires but not mod_headers.
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType image/png "access plus 30 days"
  ExpiresByType image/jpeg "access plus 30 days"
  ExpiresByType image/svg+xml "access plus 30 days"
  ExpiresByType image/webp "access plus 30 days"
  ExpiresByType text/html "access plus 0 seconds"
</IfModule>
